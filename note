import streamlit as st
from github_progress import get_user_progress, update_user_progress
from . import tab1, tab2, tab3, tab4, tab5, tab6, tab7, tab8, tab9, tab10

def safe_rerun():
    if hasattr(st, "experimental_rerun"):
        st.experimental_rerun()
    elif hasattr(st, "rerun"):
        st.rerun()
    else:
        st.error("Streamlit rerun functionality is not available.")

def show():
    username = st.session_state.get("username", "default_user")
    week = 1
    user_prog = get_user_progress(username)
    progress = user_prog.get("week1", 0)
    if progress < 1:
        progress = 1

    tab_titles = [
        "1.1 Introduction to Python",
        "1.2 You made it!",
        "1.3 What is Python?",
        "1.4 Python Script?",
        "1.5 Libraries",
        "1.6 Google Colab",
        "1.7 Assignment 1",
        "1.8 APIs",
        "1.9 Assignment 2",
        "1.10 Real-Time"
    ]
    tab_funcs = [tab1.show, tab2.show, tab3.show, tab4.show, tab5.show, tab6.show, tab7.show, tab8.show, tab9.show, tab10.show]

    tabs = st.tabs(tab_titles)

    for i, tab in enumerate(tabs):
        with tab:
            if i < progress:
                tab_funcs[i]()
            else:
                st.info("This tab is locked. Please complete previous tabs to unlock.")

            if i == progress - 1 and progress < len(tab_titles):
                if f"marking_week1_tab{i+1}" not in st.session_state:
                    st.session_state[f"marking_week1_tab{i+1}"] = False
                
                if st.button("Mark as Read", key=f"week1_tab{i+1}", disabled=st.session_state[f"marking_week1_tab{i+1}"]):
                    st.session_state[f"marking_week1_tab{i+1}"] = True  # Disable button immediately
                    update_user_progress(username, week, progress + 1)
                    st.info("Progress updated. Please click on the next tab to view the content.")
                    safe_rerun()

if __name__ == "__main__":
    show()

