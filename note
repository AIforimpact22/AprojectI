import streamlit as st
import os
from datetime import datetime
from GitHub_push import push_update_to_github, delete_update_from_github

def safe_rerun():
    if hasattr(st, "experimental_rerun"):
        st.experimental_rerun()
    elif hasattr(st, "rerun"):
        st.rerun()
    else:
        st.error("Streamlit rerun functionality is not available.")

# Folder where new tab files are stored
UPDATES_FOLDER = "updates"
if not os.path.exists(UPDATES_FOLDER):
    os.makedirs(UPDATES_FOLDER)

# Helper function to list update files (only files ending with "update.py")
def list_update_files():
    files = [f for f in os.listdir(UPDATES_FOLDER) if f.endswith("update.py")]
    return sorted(files)

# Initialize session state variables
if "editing_file" not in st.session_state:
    st.session_state["editing_file"] = None
if "show_confirm_delete" not in st.session_state:
    st.session_state["show_confirm_delete"] = None
if "authenticated" not in st.session_state:
    st.session_state["authenticated"] = False

# Custom CSS for styling
st.markdown("""
<style>
    .main-header {
        color: #4A90E2;
        font-size: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }
    .subheader {
        color: #2E7D32;
        font-size: 1.5rem;
        margin: 1.5rem 0;
    }
    .file-card {
        background-color: #f5f7fa;
        border-radius: 5px;
        padding: 10px;
        margin: 5px 0;
        border-left: 4px solid #4A90E2;
    }
    .success-msg {
        background-color: #D4EDDA;
        color: #155724;
        padding: 10px;
        border-radius: 5px;
        margin: 10px 0;
    }
    .error-msg {
        background-color: #F8D7DA;
        color: #721C24;
        padding: 10px;
        border-radius: 5px;
        margin: 10px 0;
    }
    .info-block {
        background-color: #E2F3F5;
        padding: 15px;
        border-radius: 5px;
        margin: 15px 0;
    }
    .login-container {
        max-width: 400px;
        margin: 0 auto;
        padding: 20px;
        background-color: #f8f9fa;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
</style>
""", unsafe_allow_html=True)

# Application header
st.markdown("<h1 class='main-header'>Update Tabs Manager</h1>", unsafe_allow_html=True)

# Password protection
if not st.session_state["authenticated"]:
    st.markdown("<div class='login-container'>", unsafe_allow_html=True)
    st.subheader("Login Required")
    password = st.text_input("Enter Admin Password", type="password")
    if st.button("Login"):
        # The admin password is now read from st.secrets
        if password == st.secrets["general"]["admin_password"]:
            st.session_state["authenticated"] = True
            safe_rerun()
        else:
            st.error("Incorrect password. Please try again.")
    st.markdown("</div>", unsafe_allow_html=True)

# Only show the main application if authenticated
elif st.session_state["authenticated"]:
    # --------------------------------------------------
    # Edit Mode: If a file is selected for editing
    # --------------------------------------------------
    if st.session_state["editing_file"]:
        st.markdown("<h2 class='subheader'>Edit Tab</h2>", unsafe_allow_html=True)
        
        file_to_edit = st.session_state["editing_file"]
        filepath = os.path.join(UPDATES_FOLDER, file_to_edit)
        
        # Display file info
        st.markdown(f"<div class='info-block'>Editing: <strong>{file_to_edit}</strong></div>", unsafe_allow_html=True)
        
        try:
            with open(filepath, "r", encoding="utf-8") as f:
                file_content = f.read()
        except Exception as e:
            st.error(f"Could not read {file_to_edit}: {e}")
            file_content = ""
        
        # Text editor with syntax highlighting
        new_content = st.text_area("Edit Tab Script", value=file_content, height=400)
        
        # Action buttons in columns
        col1, col2, col3 = st.columns([1, 1, 3])
        if col1.button("💾 Save Changes", use_container_width=True):
            try:
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write(new_content)
                # Push updated file to GitHub
                result = push_update_to_github(filepath)
                if result.get("success"):
                    st.markdown("<div class='success-msg'>✅ Tab updated and pushed to GitHub successfully!</div>", unsafe_allow_html=True)
                else:
                    st.markdown(f"<div class='error-msg'>❌ GitHub push failed: {result.get('error')}</div>", unsafe_allow_html=True)
                st.session_state["editing_file"] = None
                st.success("Tab updated successfully!")
                safe_rerun()
            except Exception as e:
                st.error(f"Error updating file: {e}")
        
        if col2.button("❌ Cancel", use_container_width=True):
            st.session_state["editing_file"] = None
            safe_rerun()

    # --------------------------------------------------
    # Create New Tab Mode
    # --------------------------------------------------
    else:
        # Create new tab form with sections
        with st.expander("✨ Create New Tab", expanded=True):
            st.markdown("<h2 class='subheader'>Create New Tab</h2>", unsafe_allow_html=True)
            
            # Layout using columns for form elements
            col1, col2 = st.columns(2)
            with col1:
                week = st.selectbox(
                    "Select Week",
                    options=["Week 1", "Week 2", "Week 3", "Week 4", "Week 5"],
                    help="Choose which week this update belongs to"
                )
            
            with col2:
                tab_title = st.text_input(
                    "Enter Tab Title",
                    placeholder="e.g., 1.1.2 New Updates",
                    help="Format: [Number] [Title]"
                )
            
            # Content editor
            tab_content = st.text_area(
                "Enter Tab Content",
                placeholder="Enter the content for this tab. You can use markdown formatting.",
                height=250
            )
            
            if st.button("✅ Save New Tab", use_container_width=True):
                if not tab_title:
                    st.markdown("<div class='error-msg'>❌ Tab title is required.</div>", unsafe_allow_html=True)
                else:
                    # Extract the identifier from the tab title (assumes the first token is the numeric identifier)
                    identifier = tab_title.split()[0]
                    filename = f"{identifier}update.py"  # e.g., "1.1.2update.py"
                    filepath = os.path.join(UPDATES_FOLDER, filename)
                    
                    # Generate template code with the provided title and content
                    code = f'''import streamlit as st

TAB_TITLE = "{tab_title}"

# Week: {week}
def show():
    st.markdown("<h1 style='color:gold;'>{tab_title}</h1>", unsafe_allow_html=True)
    st.markdown(
    """{tab_content}"""
    )
'''
                    try:
                        # Save the file locally
                        with open(filepath, "w", encoding="utf-8") as f:
                            f.write(code)
                        
                        # Push the new file to GitHub
                        result = push_update_to_github(filepath)
                        if result.get("success"):
                            st.markdown(
                                f"<div class='success-msg'>✅ New tab '{tab_title}' created and pushed to GitHub successfully at {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}!</div>",
                                unsafe_allow_html=True
                            )
                        else:
                            st.markdown(f"<div class='error-msg'>❌ GitHub push failed: {result.get('error')}</div>", unsafe_allow_html=True)
                        safe_rerun()
                    except Exception as e:
                        st.markdown(f"<div class='error-msg'>❌ Error saving new tab: {e}</div>", unsafe_allow_html=True)

        # --------------------------------------------------
        # List Existing Update Tabs with Edit and Delete Options
        # --------------------------------------------------
        st.markdown("<h2 class='subheader'>Existing Update Tabs</h2>", unsafe_allow_html=True)
        
        update_files = list_update_files()
        if update_files:
            # Create a card-like display for each file
            for file in update_files:
                with st.container():
                    st.markdown(f"<div class='file-card'>", unsafe_allow_html=True)
                    col1, col2, col3, col4 = st.columns([3, 1, 1, 1])
                    
                    # Try to extract tab title from file
                    filepath = os.path.join(UPDATES_FOLDER, file)
                    try:
                        with open(filepath, "r", encoding="utf-8") as f:
                            content = f.read()
                            title_line = [line for line in content.split('\n') if 'TAB_TITLE' in line]
                            if title_line:
                                display_title = title_line[0].split('=')[1].strip().strip('"\'')
                            else:
                                display_title = file
                    except:
                        display_title = file
                    
                    col1.markdown(f"**{display_title}**<br><small style='color:#666'>{file}</small>", unsafe_allow_html=True)
                    
                    # Edit button
                    if col2.button("📝 Edit", key=f"edit_{file}"):
                        st.session_state["editing_file"] = file
                        safe_rerun()
                    
                    # Delete button with confirmation
                    if col3.button("🗑️ Delete", key=f"delete_{file}"):
                        st.session_state["show_confirm_delete"] = file
                    
                    # Show confirmation dialog for deletion
                    if st.session_state["show_confirm_delete"] == file:
                        if col4.button("✓ Confirm", key=f"confirm_{file}"):
                            filepath = os.path.join(UPDATES_FOLDER, file)
                            # Attempt deletion from GitHub first
                            del_result = delete_update_from_github(filepath)
                            if del_result.get("success"):
                                st.markdown("<div class='success-msg'>✅ File deleted from GitHub.</div>", unsafe_allow_html=True)
                            else:
                                st.markdown(f"<div class='error-msg'>❌ GitHub deletion failed: {del_result.get('error')}</div>", unsafe_allow_html=True)
                            
                            # Then delete locally
                            try:
                                os.remove(filepath)
                                st.markdown("<div class='success-msg'>✅ File deleted locally.</div>", unsafe_allow_html=True)
                                st.session_state["show_confirm_delete"] = None
                                safe_rerun()
                            except Exception as e:
                                st.markdown(f"<div class='error-msg'>❌ Error deleting file locally: {e}</div>", unsafe_allow_html=True)
                    
                    st.markdown("</div>", unsafe_allow_html=True)
        else:
            st.markdown("<div class='info-block'>No update tabs found. Create your first tab above!</div>", unsafe_allow_html=True)

    # Logout button
    if st.sidebar.button("Logout"):
        st.session_state["authenticated"] = False
        safe_rerun()





