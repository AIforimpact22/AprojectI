import sqlite3

def create_database(db_path="updates.db"):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    # Create a table called "updates" with columns for tab name, title, video URL, and content.
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS updates (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            tab_name TEXT NOT NULL,
            title TEXT NOT NULL,
            video_url TEXT,
            content TEXT
        )
    ''')
    conn.commit()
    conn.close()

if __name__ == "__main__":
    create_database()
    print("Database and table created successfully.")
